generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AlternativeOption {
  A
  B
  C
  D
  E
}

model User {
  id           String       @id @default(cuid())
  name         String?
  email        String       @unique
  passwordHash String
  answers      UserAnswer[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Question {
  id           String       @id @default(cuid())
  statement    String
  discipline   String
  subject      String
  board        String
  year         Int
  explanation  String
  imageUrl     String?
  alternatives Alternative[]
  answers      UserAnswer[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([discipline])
  @@index([subject])
}

model Alternative {
  id         String            @id @default(cuid())
  option     AlternativeOption
  text       String
  isCorrect  Boolean           @default(false)
  questionId String
  question   Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers    UserAnswer[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([questionId, option])
  @@index([questionId])
}

model UserAnswer {
  id             String            @id @default(cuid())
  userId         String
  questionId     String
  alternativeId  String
  selectedOption AlternativeOption
  isCorrect      Boolean
  answeredAt     DateTime          @default(now())
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  alternative    Alternative       @relation(fields: [alternativeId], references: [id], onDelete: Cascade)

  @@index([userId, answeredAt])
  @@index([questionId])
  @@index([userId, questionId])
}
